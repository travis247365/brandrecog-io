# BrandCog MVP — environment. The demo runs fully on defaults (mock-first, no secrets).
PORT=3000

# Mock-first: 1 (default) uses the synthetic Lusaka sample via MockDataAdapter.
# Set MOCK=0 only once a real DataPort adapter (CLIP pipeline / Postgres) is wired.
MOCK=1

# Optional overrides
# PUBLIC_DIR=./public
# SAMPLE_DATA_PATH=./server/data/campaign.sample.json
