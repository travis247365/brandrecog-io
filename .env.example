# BrandCog MVP — environment. The demo runs fully on defaults (mock-first, no secrets).
PORT=3000

# Mock-first: 1 (default) uses the synthetic Lusaka sample via MockDataAdapter.
# Set MOCK=0 only once a real DataPort adapter (CLIP pipeline / Postgres) is wired.
MOCK=1

# Optional overrides
# PUBLIC_DIR=./public
# SAMPLE_DATA_PATH=./server/data/campaign.sample.json

# ── Production secrets (set via `fly secrets set …`, never commit real values) ──
# ADMIN_KEY gates the leads/PII export (/api/leads). MUST be a strong, unique value
# in production — the source default is for local mock dev only.
# ADMIN_KEY=change-me-in-prod
#
# GOOGLE_MAPS_API_KEY switches the map from free OpenStreetMap to Google Maps.
# Leave unset to stay on free OSM (default). Set only for paying clients who opt in.
# GOOGLE_MAPS_API_KEY=
#
# Lead-alert email (R2BL prospect profile on every new lead). Sending is gated on
# RESEND_API_KEY presence (NOT on MOCK) — unset = mock mode (logs only, no send).
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=alerts@travispaulconsulting.co   # internal alert sender; must be a Resend-verified domain
# RESEND_TO_EMAIL=travis.mulenga@gmail.com           # internal alert recipient (sales)
# Customer-facing waitlist confirmation sender (verified domain; supports "Name <addr>"):
# RESEND_CONFIRM_FROM_EMAIL=BrandRecog.io <hello@travispaulconsulting.co>  # switch to hello@brandrecog.io once that domain is registered+verified
# PUBLIC_SITE_URL=https://brandcog-io.fly.dev        # links used in confirmation email
#
# Note: client login is an intentional PUBLIC demo — the login page documents the
# scheme (username = brand key, password = <key>2026). Demo data only; no PII.
